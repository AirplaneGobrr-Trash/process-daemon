{
  "name": "@airplanegobrr/custom-pm2",
  "type": "module",
  "exports": {
    ".": {
      "import": "./projects/client/index.ts",
      "types": "./projects/types.ts"
    }
  },
  "scripts": {
    "server": "cd projects/server && bun server.ts",
    "serverPM2": "cd projects/server && pm2 start --name \"Better PM2\" --interpreter ~/.bun/bin/bun server.ts",
    "link": "cd projects/client && bun link"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/pidusage": "^2.0.5",
    "axios": "^1.13.2",
    "bun.db": "^1.1.4",
    "express": "^5.2.1",
    "pidusage": "^4.0.1"
  }
}
